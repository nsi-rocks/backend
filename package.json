{
  "name": "nsi-rocks-backend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:remote": "CLOUDFLARE_DEV_CONFIG_PATH=./wrangler.remote.jsonc nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "drizzle:gen": "drizzle-kit generate",
    "drizzle:push": "npx wrangler d1 migrations apply nsi-rocks --remote",
    "drizzle:push:local": "pnpm exec wrangler d1 migrations apply nsi-rocks --local --persist-to ./.wrangler/state",
    "d1:backup:remote": "./scripts/d1/backup-remote.sh",
    "d1:clone:remote-to-local": "./scripts/d1/clone-remote-to-local.sh"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@nuxt/eslint": "^1.15.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.2.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-authorization": "^0.3.5",
    "typescript": "^6.0.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "wrangler": "^4.80.0"
  }
}
